# LLM (translation / dialogue reasoning)
ANTHROPIC_API_KEY=

# Streaming speech-to-text
DEEPGRAM_API_KEY=

# Streaming text-to-speech
CARTESIA_API_KEY=

# Pipecat small-webrtc transport (browser client signaling)
# Default host/port for the local webrtc signaling server during development.
WEBRTC_HOST=0.0.0.0
WEBRTC_PORT=7860

# Translation direction. The LLM auto-detects the spoken language and
# translates into TARGET_LANG (falling back to SOURCE_LANG if the speaker
# already used the target language). Defaults to Chinese -> English.
SOURCE_LANG=Chinese
TARGET_LANG=English
