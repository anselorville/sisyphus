# LLM (translation / dialogue reasoning)
ANTHROPIC_API_KEY=

# Streaming speech-to-text
DEEPGRAM_API_KEY=

# Streaming text-to-speech
CARTESIA_API_KEY=

# Pipecat small-webrtc transport (browser client signaling)
# Default host/port for the local webrtc signaling server during development.
WEBRTC_HOST=0.0.0.0
WEBRTC_PORT=7860

# Translation direction. The LLM auto-detects the spoken language and
# translates into TARGET_LANG (falling back to SOURCE_LANG if the speaker
# already used the target language). Defaults to Chinese -> English.
SOURCE_LANG=Chinese
TARGET_LANG=English

# --- Engine selection ---
# Which STT/LLM/TTS engine trio to use. One of:
#   auto    (default) -- probe for a working internet connection at startup
#             and use "cloud" if found, "offline" if not (see
#             app/connectivity.py and app/pipeline.py).
#   cloud   -- always use Deepgram + Anthropic + Cartesia. Requires
#             ANTHROPIC_API_KEY/DEEPGRAM_API_KEY/CARTESIA_API_KEY above.
#   offline -- always use the Pi-portable local fallback (faster-whisper +
#             Ollama + Piper, configured below). No cloud keys needed.
#   omlx    -- always use the Mac-only oMLX dev/test engine (configured
#             below). NOT Pi-portable (Apple Silicon/MLX only) -- for fast
#             local iteration without spending cloud credits or needing
#             network access. No cloud keys needed.
# The legacy FORCE_OFFLINE=true/FORCE_ONLINE=true flags are still honored
# (mapped to ENGINE=offline/ENGINE=cloud) if ENGINE itself is unset.
ENGINE=auto
FORCE_OFFLINE=false
FORCE_ONLINE=false

# Local STT: faster-whisper model size (via Pipecat's WhisperSTTService).
# "small" balances accuracy/speed reasonably for a Raspberry Pi 5; drop to
# "base" or "tiny" for faster/lower-accuracy, or up to "medium" for
# slower/higher-accuracy. See https://github.com/SYSTRAN/faster-whisper for
# the full model list.
WHISPER_MODEL=small

# Local translation: a locally-running Ollama server (OpenAI-compatible API)
# and a small instruct model pulled into it ahead of time, e.g.:
#   ollama pull qwen2.5:1.5b
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen2.5:1.5b

# Local TTS: Piper voice model identifier (via Pipecat's PiperTTSService).
# Downloaded automatically into PIPER_DOWNLOAD_DIR on first use if not
# already present there. See https://github.com/OHF-Voice/piper1-gpl for
# the full voice list (pick one matching TARGET_LANG).
PIPER_VOICE=en_US-lessac-medium
PIPER_DOWNLOAD_DIR=./models/piper

# --- oMLX (Mac-only dev/test engine, NOT Pi-portable) ---
# A local oMLX server (https://github.com/, OpenAI-API-compatible) running
# on this machine with three models loaded: a chat/LLM model, an STT model,
# and a TTS model. See README.md for setup. oMLX depends on Apple's MLX
# framework, which is Apple-Silicon-only -- this engine exists purely for
# fast local iteration on a Mac dev machine, never for the Raspberry Pi
# deployment target.
OMLX_BASE_URL=http://127.0.0.1:6789/v1
# Local dev-only secret -- put the real value in .env, never commit it.
OMLX_API_KEY=
OMLX_LLM_MODEL=Qwen3.5-4B-MLX-4bit
OMLX_STT_MODEL=nemotron-3.5-asr-streaming-0.6b
OMLX_TTS_MODEL=VoxCPM2-8bit
