# LLM (translation / dialogue reasoning)
ANTHROPIC_API_KEY=

# Streaming speech-to-text
DEEPGRAM_API_KEY=

# Streaming text-to-speech
CARTESIA_API_KEY=

# Pipecat small-webrtc transport (browser client signaling)
# Default host/port for the local webrtc signaling server during development.
WEBRTC_HOST=0.0.0.0
WEBRTC_PORT=7860

# Translation direction. The LLM auto-detects the spoken language and
# translates into TARGET_LANG (falling back to SOURCE_LANG if the speaker
# already used the target language). Defaults to Chinese -> English.
SOURCE_LANG=Chinese
TARGET_LANG=English

# --- Offline/local fallback ---
# By default, the server checks for a working internet connection at
# startup and automatically uses local/offline STT+LLM+TTS services if none
# is found (see app/connectivity.py and app/pipeline.py). Set one of the
# flags below to override that automatic choice, e.g. for testing the
# offline path without physically disconnecting your network. Setting both
# is an error.
FORCE_OFFLINE=false
FORCE_ONLINE=false

# Local STT: faster-whisper model size (via Pipecat's WhisperSTTService).
# "small" balances accuracy/speed reasonably for a Raspberry Pi 5; drop to
# "base" or "tiny" for faster/lower-accuracy, or up to "medium" for
# slower/higher-accuracy. See https://github.com/SYSTRAN/faster-whisper for
# the full model list.
WHISPER_MODEL=small

# Local translation: a locally-running Ollama server (OpenAI-compatible API)
# and a small instruct model pulled into it ahead of time, e.g.:
#   ollama pull qwen2.5:1.5b
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen2.5:1.5b

# Local TTS: Piper voice model identifier (via Pipecat's PiperTTSService).
# Downloaded automatically into PIPER_DOWNLOAD_DIR on first use if not
# already present there. See https://github.com/OHF-Voice/piper1-gpl for
# the full voice list (pick one matching TARGET_LANG).
PIPER_VOICE=en_US-lessac-medium
PIPER_DOWNLOAD_DIR=./models/piper
